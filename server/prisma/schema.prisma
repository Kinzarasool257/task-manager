generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
  IN_REVIEW
}

enum MemberRole {
  ADMIN
  MEMBER
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  image      String?
  externalId String   @unique // For syncing with Kinde
  preferences Json?     @default("{}")
  members    Member[]
  notifications Notification[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Workspace {
  id          String    @id @default(cuid())
  name        String
  description String?
  inviteCode  String    @unique @default(uuid())
  plan        String    @default("FREE")
  ownerId     String
  projects    Project[]
  members     Member[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]
  members     Member[]  // Added many-to-many link to members
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  priority    String?    @default("MEDIUM")
  assignee    String?
  startDate   DateTime?
  dueDate     DateTime?
  documentation String?  @db.Text
  comments    Json?      @default("[]")
  attachments Json?      @default("[]")
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Member {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        MemberRole @default(MEMBER)
  projects    Project[]  // Added many-to-many link to projects
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, workspaceId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // e.g. "INVITE", "SYSTEM"
  icon      String   @default("bell") // "invite" or "bell"
  title     String
  body      String?  @db.Text
  sender    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
